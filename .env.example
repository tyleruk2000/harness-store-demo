# Copy to .env and adjust as needed:  cp .env.example .env
# These defaults work out of the box with `docker compose up --build`.

# --- PostgreSQL ---
POSTGRES_USER=crux
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_DB=crux
POSTGRES_PORT=5432

# --- Backend ---
# DATABASE_URL uses the psycopg v3 driver and the compose service name `postgres`.
DATABASE_URL=postgresql+psycopg://crux:change_me_local_dev@postgres:5432/crux
ENV=development
# Demo admin passcode — required (as X-Admin-Passcode header) to add/edit products.
ADMIN_PASSCODE=belay-on
# Comma-separated allowed CORS origins (browser uses the same-origin /api proxy,
# so this mainly matters for direct API calls / tooling).
CORS_ORIGINS=http://localhost:3000
RUN_MIGRATIONS_ON_START=true
SEED_ON_STARTUP=true
BACKEND_PORT=8000

# --- Frontend ---
# Server-side runtime URL the Next.js /api proxy forwards to (NOT baked into the
# client bundle). Uses the compose service name `backend`.
BACKEND_URL=http://backend:8000
FRONTEND_PORT=3000
